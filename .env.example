# NuKava CRM environment variables
#
# The app works WITHOUT these (it falls back to on-device storage with sample data).
# To enable cross-device cloud sync, create a free Supabase project and paste the
# values below, then restart the app. See README.md for step-by-step instructions.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
