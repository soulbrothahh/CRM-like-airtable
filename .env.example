# ============================================================
# NuKava CRM environment variables
# ============================================================
# The app works WITHOUT any of these (it falls back to on-device storage with
# sample data). Add the Supabase keys to enable cross-device cloud sync + login,
# and the email keys to enable daily follow-up reminder emails.
# See README.md for step-by-step instructions.

# ---- Cloud sync + login (Supabase) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================
# Email reminders (optional) — daily follow-up digest
# ============================================================
# Only needed if you want the daily reminder email. Set these in Vercel.

# Service role key from Supabase → Project Settings → API.
# Lets the scheduled job read your contacts (keep this SECRET — server only).
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key from https://resend.com (free tier). Server only — keep secret.
RESEND_API_KEY=

# Where reminder emails are sent (your email).
REMINDER_EMAIL_TO=

# From address. Leave as-is to use Resend's test sender (only delivers to your
# own Resend account email). Use a verified domain for real sending.
REMINDER_EMAIL_FROM=NuKava CRM <onboarding@resend.dev>

# Protects the /api/reminders endpoint. Vercel Cron sends this automatically as
# a Bearer token when set. Use any long random string.
CRON_SECRET=

# Your deployed app URL, used for links inside the email (e.g. https://nukava.vercel.app).
NEXT_PUBLIC_APP_URL=

# ============================================================
# AI outreach drafting (optional) — Outreach tab "Generate with AI"
# ============================================================
# Anthropic API key from https://console.anthropic.com. Without it, the Outreach
# tab still works using the built-in templates; with it, you can draft custom,
# personalized messages. Server only — keep secret.
ANTHROPIC_API_KEY=

# Optional model override for outreach drafting (defaults to claude-opus-4-8).
OUTREACH_MODEL=
